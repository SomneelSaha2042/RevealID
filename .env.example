DATABASE_URL=postgresql://revealid:revealid@localhost:5432/revealid?schema=public
API_HOST=127.0.0.1
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=/api
AUTH_ACCESS_TOKEN_SECRET=replace-with-at-least-32-characters
AUTH_REFRESH_TOKEN_SECRET=replace-with-at-least-32-characters
