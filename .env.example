# Leave empty in local development to generate an ephemeral issuer key. Set a real Ed25519 private JWK in production.
ISSUER_PRIVATE_JWK=
ISSUER_ID=http://localhost:4000
ISSUER_NAME=Demo University
COOKIE_SECURE=false
