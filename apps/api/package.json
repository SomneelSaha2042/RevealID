{
  "name": "@revealid/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build:deps": "pnpm --filter @revealid/contracts --filter @revealid/crypto build",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "start:railway": "prisma migrate deploy && node dist/src/server.js",
    "lint": "eslint .",
    "typecheck": "pnpm run build:deps && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "pnpm run build:deps && vitest run --environment node",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@prisma/client": "^6.0.0",
    "@revealid/contracts": "workspace:*",
    "@revealid/crypto": "workspace:*",
    "@trustvc/trustvc": "^2.14.1",
    "argon2": "^0.41.1",
    "ethers": "5.8.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "jose": "^5.10.0",
    "pino": "^9.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "tsx": "^4.19.2"
  }
}
