generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  HOLDER
  ISSUER
}

model User {
  id           String           @id @default(uuid()) @db.Uuid
  email        String           @unique
  name         String
  role         Role             @default(HOLDER)
  passwordHash String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  refreshTokens RefreshSession[]
  holderKey    HolderKey?
  heldCredentials Credential[]  @relation("HolderCredentials")
  issuedCredentials Credential[] @relation("IssuerCredentials")
  shares       Share[]
}

model RefreshSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique
  csrfToken String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  rotatedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model HolderKey {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @db.Uuid
  publicJwk             Json
  encryptedPrivateJwk   Json
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Credential {
  id                    String   @id @default(uuid()) @db.Uuid
  holderId              String   @db.Uuid
  issuerId              String   @db.Uuid
  credentialType        String
  issuerName            String
  encryptedSdJwt        Json
  issuedAt              DateTime
  createdAt             DateTime @default(now())
  holder                User     @relation("HolderCredentials", fields: [holderId], references: [id], onDelete: Cascade)
  issuer                User     @relation("IssuerCredentials", fields: [issuerId], references: [id], onDelete: Restrict)
  shares                Share[]

  @@index([holderId, issuedAt])
  @@index([issuerId])
}

model Share {
  id                    String   @id @default(uuid()) @db.Uuid
  holderId              String   @db.Uuid
  credentialId          String   @db.Uuid
  tokenHash             String   @unique
  audience              String
  nonce                 String
  keyBindingIssuedAt    Int
  encryptedPresentation Json
  disclosedClaims       String[]
  privateClaims         String[]
  expiresAt             DateTime
  maxViews              Int
  views                 Int      @default(0)
  revokedAt             DateTime?
  createdAt             DateTime @default(now())
  holder                User     @relation(fields: [holderId], references: [id], onDelete: Cascade)
  credential            Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([holderId, createdAt])
  @@index([credentialId])
  @@index([expiresAt])
}
